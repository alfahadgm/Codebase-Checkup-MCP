{
  "name": "checkup-mcp",
  "version": "1.0.0",
  "description": "MCP server for comprehensive codebase audits — 10-phase gap analysis for vibe coders",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "checkup-mcp": "./bin/checkup-mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "keywords": [
    "mcp",
    "audit",
    "codebase",
    "security",
    "architecture",
    "gap-analysis",
    "code-review"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
